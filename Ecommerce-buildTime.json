  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item.",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after discount.",
            "format": "double",
            "example": 24.5
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "SKU123456"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of items ordered.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code used for the amounts in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "123",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 39.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total price of all items before discounts",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount amount applied to the cart",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-15T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user owning the cart",
            "example": "user_789"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount deducted from the original price as a discount",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The total price after applying discounts",
            "format": "double",
            "example": 19.99
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 25.99
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "PROD-1001"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for the product",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the order was created",
            "example": "2024-06-01T14:25:43Z"
          },
          "currency": {
            "type": "string",
            "description": "Currency code for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD-9876543210"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 59.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total order amount before discounts",
            "format": "double",
            "example": 69.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the order was last updated",
            "example": "2024-06-02T09:18:30Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user-123456"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 99.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The payment gateway used for processing",
            "example": "Stripe"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The method of payment chosen by the user",
            "example": "credit_card"
          }
