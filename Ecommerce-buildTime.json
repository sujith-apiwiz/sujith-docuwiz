      "name": "CartService",
      "description": "Handles operations related to shopping carts, including adding, updating, and removing items."
    },
    {
      "name": "ProductService",
      "description": "Manages product information, including retrieval, search, and catalog management."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping details and tracking for customer orders."
    },
    {
      "name": "PaymentService",
      "description": "Processes payments and handles related transactions securely."
    },
    {
      "name": "OrderService",
      "description": "Manages order creation, status updates, and history."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    }
  ],
