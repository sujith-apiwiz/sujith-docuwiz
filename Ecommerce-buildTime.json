{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "The Ecommerce-buildTime API provides a comprehensive suite of services to manage an online shopping experience including user account management, product listing, cart operations, order processing, payment handling, and shipment tracking. It enables seamless integration for creating and managing user carts, placing and tracking orders, initiating payments with webhook support, and handling shipping details.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
