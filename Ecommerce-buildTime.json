{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "The Ecommerce-buildTime API provides comprehensive services for managing an e-commerce platform. It includes endpoints for product management, user management, shopping cart operations, order placements, payment processing, and shipping tracking, enabling seamless integration and effective control over the entire e-commerce workflow.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce Support Team",
      "url": "https://www.ecommerce-buildtime.com/contact",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
  "tags": [
    {
      "name": "PaymentService",
      "description": "Handles payment processing and transaction management."
    },
    {
      "name": "ShippingService",
      "description": "Manages shipping options, tracking, and delivery statuses."
    },
    {
      "name": "CartService",
      "description": "Manages the shopping cart including adding, updating, and removing items."
    },
    {
      "name": "ProductService",
      "description": "Provides product information, inventory status, and catalog management."
    },
    {
      "name": "OrderService",
      "description": "Handles order creation, status tracking, and order history."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    }
  ],
  "paths": {
    "/cart/{userId}": {
      "get": {
        "tags": [
          "CartService"
        ],
        "summary": "Retrieve user shopping cart",
        "description": "Fetches the current shopping cart details for the specified user. This includes all items added to the cart and their quantities.",
        "operationId": "getCart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/cart/{userId}/add": {
      "post": {
        "tags": [
          "CartService"
        ],
        "summary": "Add item to user cart",
        "description": "Adds a specified product to the user's shopping cart. This endpoint updates the cart with new items or increases the quantity of existing ones.",
        "operationId": "addToCart",
        "parameters": [],
        "requestBody": {
          "description": "Represents the item details to be added to a user's shopping cart.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "abc123",
                "quantity": 2,
                "options": {
                  "color": "red",
                  "size": "M"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/place/{userId}": {
      "post": {
        "tags": [
          "OrderService"
        ],
        "summary": "Submit new order",
        "description": "Creates and places an order for the specified user using the items in their cart. This finalizes the purchase process, reserving the items for shipment.",
        "operationId": "placeOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/{orderId}": {
      "get": {
        "tags": [
          "OrderService"
        ],
        "summary": "Retrieve order details",
        "description": "Gets detailed information about a specific order by its ID. Includes status, items, pricing, and shipping information.",
        "operationId": "getOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/orderId"
        }
      ]
    },
    "/payments/initiate": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Start payment process",
        "description": "Begins the payment procedure for an order. This returns payment instructions or redirects needed to complete the transaction.",
        "operationId": "initiatePayment",
        "parameters": [],
        "requestBody": {
          "description": "Contains the details required to start a payment transaction.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_request"
              },
              "example": {
                "amount": 49.99,
                "currency": "USD",
                "paymentMethod": "credit_card",
                "orderId": "order789"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/payments/webhook": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Handle payment notifications",
        "description": "Receives payment status updates from the payment gateway. Used to update order status based on successful or failed payment attempts.",
        "operationId": "paymentWebhook",
        "parameters": [],
        "requestBody": {
          "description": "Data sent by the payment provider to notify about payment status updates.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_webhook"
              },
              "example": {
                "transactionId": "txn456",
                "status": "completed",
                "amount": 49.99,
                "currency": "USD",
                "timestamp": "2024-06-01T12:00:00Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/products": {
      "post": {
        "tags": [
          "ProductService"
        ],
        "summary": "Create new product",
        "description": "Adds a new product to the catalog. Requires product details such as name, description, price, and inventory information.",
        "operationId": "addProduct",
        "parameters": [],
        "requestBody": {
          "description": "Details of a new product to be added to the product catalog.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/product_request"
              },
              "example": {
                "name": "Wireless Mouse",
                "description": "Ergonomic wireless mouse with adjustable DPI.",
                "price": 25.5,
                "category": "Electronics",
                "stock": 100,
                "sku": "WM12345"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/product_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/shipping/{orderId}/track": {
      "get": {
        "tags": [
          "ShippingService"
        ],
        "summary": "Get order shipment status",
        "description": "Tracks the shipping status of a given order. Provides real-time updates on delivery progress and estimated arrival times.",
        "operationId": "trackOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/tracking_response"
                }
