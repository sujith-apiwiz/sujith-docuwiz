{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime is a comprehensive API designed to facilitate seamless management of products, user carts, orders, shipping tracking, user profiles, and payments within an e-commerce platform. It provides endpoints for retrieving product information, managing shopping carts per user, placing and tracking orders, handling payment initiation and webhook notifications, managing user data, and tracking shipping details for orders.",
    "termsOfService": "https://ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
