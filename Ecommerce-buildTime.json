  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime is a comprehensive API designed to streamline online shopping experiences by managing products, users, carts, orders, payments, and shipping services. It enables seamless interactions for adding items to carts, placing orders, processing payments, tracking shipments, and managing user data to support a full-featured e-commerce platform.",
    "termsOfService": "https://ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
