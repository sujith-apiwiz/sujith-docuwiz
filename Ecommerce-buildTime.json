  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the item's pricing.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item.",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying the discount.",
            "format": "double",
            "example": 19.45
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before any discounts.",
            "format": "double",
            "example": 24.95
          },
          "productId": {
            "type": "string",
            "description": "A unique identifier for the product.",
            "example": "ABC12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently present in the shopping cart.",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount payable after applying discounts.",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total price of all items before discounts are applied.",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The cumulative discount amount applied to the cart.",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp of the last update made to the cart.",
            "example": "2024-06-15T10:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier for the user who owns the cart.",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount discounted from the original price",
            "format": "double",
            "example": 5.25
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying discounts",
            "format": "double",
            "example": 19.75
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item",
            "format": "double",
            "example": 25.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "PROD-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered",
            "example": 3
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created.",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order.",
            "example": [
              {
                "itemId": "1234",
                "name": "Bluetooth Headphones",
                "quantity": 1,
                "price": 59.99
              },
              {
                "itemId": "5678",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 15.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order.",
            "example": "ORD-20240615-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts.",
            "format": "double",
            "example": 89.99
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current status of the order.",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total price of all items before any discounts.",
            "format": "double",
            "example": 95.99
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the order.",
            "format": "double",
            "example": 6.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated.",
            "example": "2024-06-16T10:15:30Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order.",
            "example": "user_7890"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
