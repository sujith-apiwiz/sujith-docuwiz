      "name": "ProductService",
      "description": "Handles product catalog management including listing, updating, and searching products."
    },
    {
      "name": "CartService",
      "description": "Manages user shopping carts, including adding, updating, and removing items."
    },
    {
      "name": "OrderService",
      "description": "Processes customer orders, tracking order status and history."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipment and delivery of orders to customers."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    },
    {
      "name": "PaymentService",
      "description": "Processes payment transactions and manages billing information."
    }
  ],
