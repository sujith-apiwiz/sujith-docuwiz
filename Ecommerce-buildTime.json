        }
      ]
    },
    "/users": {
      "post": {
        "tags": [
          "UserService"
        ],
        "summary": "Create new user account",
        "description": "Registers a new user with the system. Collects user information necessary for account creation and access.",
        "operationId": "registerUser",
        "parameters": [],
        "requestBody": {
          "description": "Information required to create a new user account.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/user_request"
              },
              "example": {
                "username": "johndoe",
                "email": "johndoe@example.com",
                "password": "StrongP@ssw0rd!",
                "firstName": "John",
                "lastName": "Doe",
                "phone": "+1234567890"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/user_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices, following ISO 4217 format.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item price.",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying the discount.",
            "format": "double",
            "example": 44.5
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before any discounts.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the cart amounts.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart.",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount that needs to be paid after discounts.",
            "format": "double",
            "example": 39.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original amount of all items before discounts.",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart.",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated.",
            "example": "2024-06-01T12:30:45Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user who owns the cart.",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item.",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after applying discounts.",
            "format": "double",
            "example": 29.99
          },
          "price": {
            "type": "number",
            "description": "The original price of the order item before any discounts.",
            "format": "double",
            "example": 35.98
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier for the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product ordered.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units ordered for the product.",
