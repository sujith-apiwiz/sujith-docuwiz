  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code in ISO 4217 format for the item's prices",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discounts",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the cart, following ISO 4217 standard",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the shopping cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid by the user after discounts",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of all items before any discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the cart",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated",
            "example": "2024-06-15T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user owning this cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the item price",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The timestamp when the order was created",
            "example": "2024-05-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items included in the order",
            "example": [
              {
                "itemId": "item123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "itemId": "item456",
                "name": "Keyboard",
                "quantity": 1,
                "price": 45.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount payable after discounts and charges",
            "format": "double",
            "example": 65.48
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The overall status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before applying any discounts",
            "format": "double",
            "example": 75.49
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the order",
            "format": "double",
            "example": 10.01
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the order was last updated",
            "example": "2024-05-16T09:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier for the user who placed the order",
            "example": "user789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total monetary amount to be charged in the transaction.",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code in which the payment is made, following ISO 4217 standards.",
            "example": "USD"
          },
