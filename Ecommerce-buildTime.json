          },
          "paymentMethod": {
            "type": "string",
            "description": "Type of payment method used",
            "example": "Credit Card"
          }
        }
      },
      "payment_response": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount paid in the transaction",
            "format": "double",
            "example": 150.75
          },
          "createdAt": {
            "type": "string",
