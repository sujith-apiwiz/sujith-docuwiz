            "example": "2024-06-01T14:22:35Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the related order",
            "example": "ORD123456789"
          },
          "paymentId": {
            "type": "string",
            "description": "Unique identifier for this payment",
            "example": "PAY987654321"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The method used to make the payment",
            "example": "credit_card"
          },
          "status": {
            "type": "string",
            "description": "The current status of the payment",
            "example": "completed"
          },
          "transactionId": {
            "type": "string",
            "description": "Unique transaction identifier provided by the payment processor",
            "example": "TXN1122334455"
          }
        }
      },
      "payment_webhook": {
        "type": "object",
        "properties": {
          "gatewayResponse": {
            "type": "string",
            "description": "Response message from the payment gateway",
