          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier for the order.",
            "example": "ORD123456789"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount that needs to be paid after discounts.",
            "format": "double",
            "example": 51.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
