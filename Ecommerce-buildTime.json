      "description": "Manages shopping cart operations such as adding, removing, and retrieving cart items for users."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping options, tracking, and delivery status for orders."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    },
    {
      "name": "OrderService",
      "description": "Processes customer orders including order creation, updating, and history retrieval."
    },
    {
      "name": "PaymentService",
      "description": "Handles payment processing, billing, and transaction management."
    }
  ],
