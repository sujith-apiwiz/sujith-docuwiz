  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices in ISO 4217 format",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the product",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the product after applying discounts",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items currently present in the shopping cart",
            "example": [
              {
                "productId": "abc123",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable by the user after discounts",
            "format": "double",
            "example": 39.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original price of all items before any discounts",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the original total amount",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated",
            "example": "2024-06-01T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user owning the cart",
            "example": "user_789"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item.",
            "format": "double",
            "example": 5.75
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after discount.",
            "format": "double",
            "example": 19.25
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product.",
            "format": "double",
            "example": 25.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "abc123xyz"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product ordered.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created.",
            "example": "2024-04-25T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order payment.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "An array of items included in the order.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "A unique identifier for the order.",
            "example": "ORD789654123"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable for the order after discounts.",
            "format": "double",
            "example": 39.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current status of the order processing.",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before any discounts are applied.",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the order.",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated.",
            "example": "2024-04-26T09:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user who placed the order.",
            "example": "USR456789123"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 99.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The payment gateway service to process the payment",
            "example": "Stripe"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The method of payment used",
            "example": "credit_card"
          }
        }
      },
      "payment_response": {
        "type": "object",
        "properties": {
          "amount": {
