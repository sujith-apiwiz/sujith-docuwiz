  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices in ISO 4217 format",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount applied to the item price",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-1001"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "productId": "67890",
                "name": "USB-C Cable",
                "quantity": 1,
                "price": 9.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount the user needs to pay after deductions",
            "format": "double",
            "example": 59.97
          },
          "totalAmount": {
            "type": "number",
            "description": "The total price of all items before any discounts",
            "format": "double",
            "example": 61.97
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 2.0
          },
          "updatedAt": {
            "type": "string",
            "description": "ISO8601 timestamp when the cart was last updated",
            "example": "2024-06-01T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who owns the cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "Amount deducted from the original price as a discount",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "Total price to be paid after applying the discount",
            "format": "double",
            "example": 44.5
          },
          "price": {
            "type": "number",
            "description": "Original price of a single product unit before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier for the product",
            "example": "prd123456"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of product units ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-10T14:48:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "productName": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "productId": "67890",
                "productName": "USB Keyboard",
                "quantity": 1,
                "price": 45.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD-20240610-0056"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts and adjustments",
            "format": "double",
            "example": 67.49
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before any discounts are applied",
            "format": "double",
            "example": 97.48
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount amount applied to the order",
            "format": "double",
            "example": 30.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-11T09:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "user-9876"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 99.99
          },
