{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "The Ecommerce-buildTime API provides comprehensive services to manage an online shopping platform, including cart management, product browsing, user information, order processing, shipping tracking, and payment handling. It enables seamless interaction between users and the e-commerce system, supporting actions such as adding items to cart, placing orders, initiating payments, and tracking shipments.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce Support Team",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
  "tags": [
    {
      "name": "CartService",
      "description": "Handles operations related to user shopping carts including adding, removing, and updating items."
    },
    {
      "name": "ProductService",
      "description": "Manages product catalog data including retrieval, search, and filtering of products."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts and profiles including authentication and authorization."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping options, rates, and tracking information for orders."
    },
    {
      "name": "OrderService",
      "description": "Processes orders from creation to fulfillment including order status updates."
    },
    {
      "name": "PaymentService",
      "description": "Handles payment processing, billing, and transaction verification."
    }
  ],
