              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/user_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price using ISO 4217 format",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discounts",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier for the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart totals.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "The list of items currently in the cart.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts.",
            "format": "double",
            "example": 35.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before any discounts are applied.",
            "format": "double",
            "example": 40.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart.",
            "format": "double",
            "example": 4.02
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated.",
            "example": "2024-04-26T15:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user owning the cart.",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the order item, represented as a decimal value.",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying the discount.",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product before discount.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "A unique identifier for the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for this product.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The timestamp when the order was created.",
            "example": "2024-06-01T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 25.5
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 15.0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order.",
            "example": "ORD-20240601-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts and adjustments.",
            "format": "double",
            "example": 66.0
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order.",
            "example": "Pending"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order.",
            "example": "Processing"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total cost before applying any discounts.",
            "format": "double",
            "example": 75.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order.",
            "format": "double",
            "example": 9.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the order was last updated.",
            "example": "2024-06-01T15:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order.",
            "example": "user-9876"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Total amount to be paid",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "Currency code in ISO 4217 format",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
