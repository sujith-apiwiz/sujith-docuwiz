  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code for the item's price",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "Discount applied to the item price",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "Final price of the item after discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "Original price of the item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier of the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying any discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount amount applied to the cart",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated",
            "example": "2024-06-15T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item.",
            "format": "double",
            "example": 5.75
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount.",
            "format": "double",
            "example": 24.25
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "A123XYZ"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered.",
            "example": 3
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order payment",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD789456123"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts",
            "format": "double",
            "example": 51.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "example": "Processing"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount of the order before any discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T10:20:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user_987654321"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid.",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 currency code for the payment.",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier for the order associated with the payment.",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The payment gateway through which the payment will be processed.",
