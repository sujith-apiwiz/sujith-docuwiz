{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime API provides a comprehensive suite of endpoints to manage an ecommerce platform including user management, product listings, shopping cart operations, order placement and tracking, payment processing, and shipping status updates.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
  "tags": [
    {
      "name": "ShippingService",
      "description": "Handles the shipping and delivery of orders to customers."
    },
    {
      "name": "ProductService",
      "description": "Manages product information, inventory, and catalog updates."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts and profiles."
    },
    {
      "name": "OrderService",
      "description": "Processes customer orders from placement to fulfillment."
    },
    {
      "name": "PaymentService",
      "description": "Handles payment processing and transaction management."
    },
    {
      "name": "CartService",
      "description": "Manages shopping cart operations and item selections."
    }
  ],
  "paths": {
    "/cart/{userId}": {
      "get": {
        "tags": [
          "CartService"
        ],
        "summary": "Retrieve user's shopping cart",
        "description": "Fetches the current shopping cart details for the specified user. Returns all items, quantities, and prices present in the cart.",
        "operationId": "getCart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/cart/{userId}/add": {
      "post": {
        "tags": [
          "CartService"
        ],
        "summary": "Add item to user cart",
        "description": "Adds a specified product to the user's shopping cart. Updates the cart with the new item and adjusts quantities as needed.",
        "operationId": "addToCart",
        "parameters": [],
        "requestBody": {
          "description": "Request body representing the item details to add to a user's shopping cart.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "12345",
                "quantity": 2,
                "options": {
                  "color": "red",
                  "size": "M"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/place/{userId}": {
      "post": {
        "tags": [
          "OrderService"
        ],
        "summary": "Create a new order",
        "description": "Processes the user's cart to create a new order. Initiates order creation and returns order confirmation details.",
        "operationId": "placeOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/{orderId}": {
      "get": {
        "tags": [
          "OrderService"
        ],
        "summary": "Get order details",
        "description": "Retrieves detailed information about a specific order by its ID. Includes order status, items, shipping, and payment information.",
        "operationId": "getOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/orderId"
        }
      ]
    },
    "/payments/initiate": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Start payment process",
        "description": "Begins the payment process for an order. Accepts payment details and returns a transaction status or payment link.",
        "operationId": "initiatePayment",
        "parameters": [],
        "requestBody": {
          "description": "Request body containing details needed to initiate a payment transaction.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_request"
              },
              "example": {
                "amount": 49.99,
                "currency": "USD",
                "paymentMethod": "credit_card",
                "cardDetails": {
                  "cardNumber": "4111111111111111",
                  "expiryDate": "12/25",
                  "cvv": "123"
                },
                "customerId": "user_6789"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/payments/webhook": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Handle payment notifications",
        "description": "Receives and processes asynchronous payment status updates from the payment provider. Updates system records based on webhook data.",
        "operationId": "paymentWebhook",
        "parameters": [],
        "requestBody": {
          "description": "Request body sent by payment gateway to notify about payment status updates.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_webhook"
              },
              "example": {
                "transactionId": "txn_987654321",
                "status": "success",
                "amount": 49.99,
                "currency": "USD",
                "paymentMethod": "credit_card",
                "timestamp": "2024-05-20T14:25:43Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/products": {
      "post": {
        "tags": [
          "ProductService"
        ],
        "summary": "Create new product",
        "description": "Adds a new product to the product catalog. Accepts product details and returns confirmation of product creation.",
        "operationId": "addProduct",
        "parameters": [],
        "requestBody": {
          "description": "Request body to add a new product to the product catalog.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/product_request"
              },
              "example": {
                "name": "Wireless Mouse",
                "description": "Ergonomic wireless mouse with adjustable DPI.",
                "price": 29.99,
                "currency": "USD",
                "stock": 150,
                "category": "electronics",
                "tags": [
                  "peripheral",
                  "wireless",
                  "mouse"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/product_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/shipping/{orderId}/track": {
      "get": {
        "tags": [
          "ShippingService"
        ],
        "summary": "Track order shipment",
        "description": "Provides real-time tracking information for a specified order's shipment. Returns current shipping status and estimated delivery.",
        "operationId": "trackOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/tracking_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/orderId"
        }
      ]
    },
    "/users": {
      "post": {
        "tags": [
          "UserService"
        ],
        "summary": "Register a new user",
        "description": "Creates a new user account with the provided details. Returns user registration confirmation and initial account information.",
        "operationId": "registerUser",
        "parameters": [],
        "requestBody": {
          "description": "Request body containing user details to create a new user account.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/user_request"
              },
              "example": {
                "username": "johndoe",
                "email": "johndoe@example.com",
                "password": "StrongPassword!23",
                "firstName": "John",
                "lastName": "Doe",
                "phone": "+1234567890",
                "address": {
                  "street": "123 Main St",
                  "city": "Anytown",
                  "state": "CA",
                  "postalCode": "90210",
                  "country": "USA"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/user_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    }
  },
  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used in the cart, following ISO 4217 standards",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "The list of items currently in the cart",
            "example": [
              {
                "id": "item123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The original total amount of all items before discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the cart was last updated",
            "example": "2024-06-01T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier of the user owning the cart",
            "example": "user789"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price for the order item after applying discount",
            "format": "double",
            "example": 44.5
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "productId": "67890",
                "name": "USB-C Cable",
                "quantity": 1,
                "price": 12.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD-20240615-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount payable after applying discounts and taxes",
            "format": "double",
            "example": 53.97
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total original amount of the order before discounts",
            "format": "double",
            "example": 64.97
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 11.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T10:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "user_abc123"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 49.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code in ISO 4217 format",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
