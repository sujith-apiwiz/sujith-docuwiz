    "openapi": "3.0.0",
    "info": {
      "title": "E-commerce API",
      "version": "1.0.0",
      "description": "API for managing users, orders, carts, products, payments, and shipping in an e-commerce system."
    },
    "servers": [
      {
        "url": "https://api.example.com/v1",
        "description": "Production server"
      }
    ],
    "tags": [
      {
        "name": "UserService",
        "description": "Operations related to user management"
      },
      {
        "name": "OrderService",
        "description": "Operations for managing orders"
      },
      {
        "name": "CartService",
        "description": "Operations for managing shopping carts"
      },
      {
        "name": "ShippingService",
        "description": "Operations concerning shipping and tracking"
      },
      {
        "name": "ProductService",
        "description": "Operations for managing products"
      },
      {
        "name": "PaymentService",
        "description": "Operations related to payment processing"
      }
    ],
    "paths": {
      "/users": {
        "post": {
          "tags": [
            "UserService"
          ],
          "summary": "Register a new user",
          "description": "Creates a new user account in the system.",
          "operationId": "registerUser",
          "requestBody": {
            "description": "Data required to register a user.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserRequestDTO"
                },
                "examples": {
                  "successfulRequest": {
                    "summary": "Valid Request",
                    "value": {
                      "username": "johndoe",
                      "email": "johndoe@example.com",
                      "password": "x0$A2!H2+F::a"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "User registered successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/UserResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "id": "123",
                        "username": "johndoe",
                        "email": "johndoe@example.com"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid input or missing required data.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/orders/place/{userId}": {
        "post": {
          "tags": [
            "OrderService"
          ],
          "summary": "Place an order",
          "description": "Places a new order for the specified user.",
          "operationId": "placeOrder",
          "parameters": [
            {
              "name": "userId",
              "in": "path",
              "required": true,
              "description": "The unique identifier of the user placing the order.",
              "schema": {
                "type": "string",
                "example": "123"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Order placed successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/OrderResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "orderId": "order123",
                        "status": "placed",
                        "amount": 250.75
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid request payload or parameters.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/orders/{orderId}": {
        "get": {
          "tags": [
            "OrderService"
          ],
          "summary": "Get order details",
          "description": "Retrieve the details of an existing order.",
          "operationId": "getOrder",
          "parameters": [
            {
              "name": "orderId",
              "in": "path",
              "required": true,
              "description": "The unique identifier of the order.",
              "schema": {
                "type": "string",
                "example": "order123"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Order details retrieved successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/OrderResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "orderId": "order123",
                        "status": "shipped",
                        "items": [
                          {
                            "productId": "prod001",
                            "quantity": 2
                          }
                        ],
                        "amount": 100.5
                      }
                    }
                  }
                }
              }
            },
            "404": {
              "description": "Order not found.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/cart/{userId}/add": {
        "post": {
          "tags": [
            "CartService"
          ],
          "summary": "Add item to cart",
          "description": "Adds an item to the user's shopping cart.",
          "operationId": "addToCart",
          "parameters": [
            {
              "name": "userId",
              "in": "path",
              "required": true,
              "description": "The unique identifier of the user.",
              "schema": {
                "type": "string",
                "example": "123"
              }
            }
          ],
          "requestBody": {
            "description": "Data required to add an item to the cart.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CartItemDTO"
                },
                "examples": {
                  "successfulRequest": {
                    "summary": "Valid Request",
                    "value": {
                      "productId": "prod002",
                      "quantity": 1
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Item added to cart successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/CartResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "userId": "123",
                        "items": [
                          {
                            "productId": "prod002",
                            "quantity": 1
                          }
                        ]
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid input or missing required data.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/cart/{userId}": {
        "get": {
          "tags": [
            "CartService"
          ],
          "summary": "Get user cart",
          "description": "Retrieve the items in the user's shopping cart.",
          "operationId": "getCart",
          "parameters": [
            {
              "name": "userId",
              "in": "path",
              "required": true,
              "description": "The unique identifier of the user.",
              "schema": {
                "type": "string",
                "example": "123"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Cart retrieved successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/CartResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "userId": "123",
                        "items": [
                          {
                            "productId": "prod001",
                            "quantity": 2
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "/shipping/{orderId}/track": {
        "get": {
          "tags": [
            "ShippingService"
          ],
          "summary": "Track order shipment",
          "description": "Retrieve the shipment tracking information for a specific order.",
          "operationId": "trackOrder",
          "parameters": [
            {
              "name": "orderId",
              "in": "path",
              "required": true,
              "description": "The unique identifier of the order to track.",
              "schema": {
                "type": "string",
                "example": "order123"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Tracking information retrieved successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/TrackingResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "orderId": "order123",
                        "status": "In Transit",
                        "location": "Distribution Center"
                      }
                    }
                  }
                }
              }
            },
            "404": {
              "description": "Order not found or tracking not available.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/products": {
        "post": {
          "tags": [
            "ProductService"
          ],
          "summary": "Add a new product",
          "description": "Add a new product to the inventory.",
          "operationId": "addProduct",
          "requestBody": {
            "description": "Data required to add a product.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductRequestDTO"
                },
                "examples": {
                  "successfulRequest": {
                    "summary": "Valid Request",
                    "value": {
                      "name": "New Product",
                      "price": 39.99,
                      "category": "Electronics"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Product added successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProductResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "id": "prod003",
                        "name": "New Product",
                        "price": 39.99,
                        "category": "Electronics"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid input or missing required data.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/payments/webhook": {
        "post": {
          "tags": [
            "PaymentService"
          ],
          "summary": "Process payment webhook",
          "description": "Processes incoming payment notifications via webhook.",
          "operationId": "paymentWebhook",
          "requestBody": {
            "description": "The webhook payload received for processing.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentWebhookDTO"
                },
                "examples": {
                  "successfulRequest": {
                    "summary": "Valid Request",
                    "value": {
                      "transactionId": "txn456",
                      "amount": 200.0,
                      "status": "success"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Payment webhook processed successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/PaymentResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "transactionId": "txn456",
                        "status": "processed"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid webhook payload received.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      },
      "/payments/initiate": {
        "post": {
          "tags": [
            "PaymentService"
          ],
          "summary": "Initiate a payment",
          "description": "Initiate a payment transaction for an order.",
          "operationId": "initiatePayment",
          "requestBody": {
            "description": "Data required to initiate a payment.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentRequestDTO"
                },
                "examples": {
                  "successfulRequest": {
                    "summary": "Valid Request",
                    "value": {
                      "orderId": "order789",
                      "amount": 200.0,
                      "method": "credit_card"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Payment initiated successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/PaymentResponseDTO"
                  },
                  "examples": {
                    "successfulResponse": {
                      "summary": "Successful Response",
                      "value": {
                        "paymentId": "pay456",
                        "status": "initiated"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid payment initiation data.",
              "content": {
                "application/problem+json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProblemDetail"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "UserRequestDTO": {
          "title": "User Request",
          "description": "Details required to create a new user account.",
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "example": "johndoe",
              "description": "The user's desired username."
            },
            "email": {
              "type": "string",
              "format": "email",
              "example": "johndoe@example.com",
              "description": "The user's email address."
            },
            "password": {
              "type": "string",
              "minLength": 8,
              "example": "x0$A2!H2+F::a",
              "description": "The user's chosen password."
            }
          },
          "required": [
            "username",
            "email",
            "password"
          ]
        },
        "UserResponseDTO": {
          "title": "User Response",
          "description": "Response returned after user registration.",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "example": "123",
              "description": "Unique identifier for the user."
            },
            "username": {
              "type": "string",
              "example": "johndoe",
              "description": "The registered username of the user."
            },
            "email": {
              "type": "string",
              "format": "email",
              "example": "johndoe@example.com",
              "description": "The registered email address of the user."
            }
          }
        },
        "OrderResponseDTO": {
          "title": "Order Response",
          "description": "Response with details of an order.",
          "type": "object",
          "properties": {
            "orderId": {
              "type": "string",
              "example": "order123",
              "description": "Unique identifier for the order."
            },
            "status": {
              "type": "string",
              "example": "placed",
              "description": "Current status of the order."
            },
            "amount": {
              "type": "number",
              "format": "double",
              "example": 250.75,
              "description": "Total amount for the order."
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "productId": {
                    "type": "string",
                    "example": "prod001",
                    "description": "ID of the product in the order."
                  },
                  "quantity": {
                    "type": "integer",
                    "example": 2,
                    "description": "Quantity of the product ordered."
                  }
                }
              },
              "description": "List of items in the order."
            }
          }
        },
        "CartItemDTO": {
          "title": "Cart Item",
          "description": "Details of an item to be added to the cart.",
          "type": "object",
          "properties": {
            "productId": {
              "type": "string",
              "example": "prod002",
              "description": "The unique identifier of the product to add."
            },
            "quantity": {
              "type": "integer",
              "example": 1,
              "minimum": 1,
              "description": "The amount of the product to add."
            }
          },
          "required": [
            "productId",
            "quantity"
          ]
        },
        "CartResponseDTO": {
          "title": "Cart Response",
          "description": "Response with details of the user's cart.",
          "type": "object",
          "properties": {
            "userId": {
              "type": "string",
              "example": "123",
              "description": "Unique identifier for the user."
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "productId": {
                    "type": "string",
                    "example": "prod001",
                    "description": "ID of the product in the cart."
                  },
                  "quantity": {
                    "type": "integer",
                    "example": 2,
                    "description": "Quantity of the product in the cart."
                  }
                }
              },
              "description": "List of items in the user's cart."
            }
          }
        },
        "TrackingResponseDTO": {
          "title": "Tracking Response",
          "description": "Details about the shipment tracking status of an order.",
          "type": "object",
          "properties": {
            "orderId": {
              "type": "string",
              "example": "order123",
              "description": "Unique identifier for the order."
            },
            "status": {
              "type": "string",
              "example": "In Transit",
              "description": "Current status of the shipment."
            },
            "location": {
              "type": "string",
              "example": "Distribution Center",
              "description": "Current location of the shipment."
            }
          }
        },
        "ProductRequestDTO": {
          "title": "Product Request",
          "description": "Details required to add a new product.",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "example": "New Product",
              "description": "Name of the new product."
            },
