      "name": "ProductService",
      "description": "Handles product catalog management including creation, updates, and retrieval of product details."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    },
    {
      "name": "CartService",
      "description": "Manages shopping cart operations such as adding, updating, and removing items."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping options, tracking, and delivery status updates."
    },
    {
      "name": "OrderService",
      "description": "Processes orders from creation to completion, including status management and history."
    },
    {
      "name": "PaymentService",
      "description": "Handles payment processing, billing, and transaction records."
    }
  ],
