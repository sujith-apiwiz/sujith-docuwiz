  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices, in ISO 4217 format",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discounts",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "SKU123456"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code used for the cart transactions",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items added to the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Final amount payable after discounts",
            "format": "double",
            "example": 39.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying any discounts",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied on the cart",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-04-27T15:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier for the user owning the cart",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the item, represented as a decimal value.",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original unit price of the product before discounts.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product ordered.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product ordered.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-01T14:23:30Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order payment",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "itemId": "67890",
                "name": "USB Keyboard",
                "quantity": 1,
                "price": 45.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount the user needs to pay after discounts",
            "format": "double",
            "example": 70.49
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order processing",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before any discounts are applied",
            "format": "double",
            "example": 90.0
          },
          "totalDiscount": {
            "type": "number",
