  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices, following ISO 4217 standard.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item price.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying discounts.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discount.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "B07PGL2N7J"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of this product added to the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code for all prices in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 15.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 29.99
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before discounts",
            "format": "double",
            "example": 34.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart",
            "format": "double",
            "example": 4.01
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp of the last update to the cart",
            "example": "2024-04-27T14:35:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier for the user who owns the cart",
            "example": "user_98765"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the item in dollars.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying the discount.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before any discounts.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items included in the order",
            "example": [
              {
                "itemId": "item123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "itemId": "item456",
                "name": "Keyboard",
                "quantity": 1,
                "price": 45.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "order789"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts and taxes",
            "format": "double",
            "example": 70.48
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current fulfillment status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original amount before discounts",
            "format": "double",
            "example": 80.48
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the order",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T10:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user001"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid for the transaction",
            "format": "double",
            "example": 99.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code in which the payment is made",
            "example": "USD"
          },
          "orderId": {
