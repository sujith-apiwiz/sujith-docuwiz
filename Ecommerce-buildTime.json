  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item's price",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts",
            "format": "double",
            "example": 20.99
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discounts",
            "format": "double",
            "example": 25.99
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier for the product",
            "example": "ABC123XYZ"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for all monetary values in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 15.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 29.99
          },
          "totalAmount": {
            "type": "number",
            "description": "Total original amount of all items before discounts",
            "format": "double",
            "example": 35.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to all items",
            "format": "double",
            "example": 5.99
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-01T12:30:45Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who owns the cart",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 19.99
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 25.49
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product ordered",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for this product",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created.",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code in which the order amounts are specified.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 49.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order.",
            "example": "ORD-20240615-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts.",
            "format": "double",
            "example": 59.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current processing status of the order.",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of the order before discounts.",
            "format": "double",
            "example": 79.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the order.",
            "format": "double",
            "example": 20.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated.",
            "example": "2024-06-16T09:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier for the user who placed the order.",
            "example": "user-7890"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 49.99
          },
          "currency": {
            "type": "string",
            "description": "The currency of the payment in ISO 4217 format",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier of the order associated with the payment",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The payment gateway used to process the transaction",
            "example": "Stripe"
          },
