  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime is a comprehensive API designed to manage all aspects of an online store, including user management, product listings, cart operations, order processing, payment handling, and shipping tracking. It provides endpoints for creating and modifying user carts, placing and retrieving orders, initiating payments and processing payment webhooks, browsing products, and tracking shipments efficiently.",
    "termsOfService": "https://ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
