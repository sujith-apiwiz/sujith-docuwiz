{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "The Ecommerce-buildTime API provides a comprehensive set of services to manage products, users, payments, orders, carts, and shipping within an online shopping environment. It enables seamless operations such as adding products to cart, placing orders, initiating payments, tracking shipments, and managing user information.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce Support Team",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
  "tags": [
    {
      "name": "ProductService",
      "description": "Handles product catalog operations including creation, update, and retrieval."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts and profiles."
    },
    {
      "name": "PaymentService",
      "description": "Processes payments and manages transaction records."
    },
    {
      "name": "OrderService",
      "description": "Handles order creation, tracking, and management."
    },
    {
      "name": "CartService",
      "description": "Manages shopping cart contents and user interactions."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping logistics and tracks shipment status."
    }
  ],
  "paths": {
    "/cart/{userId}": {
      "get": {
        "tags": [
          "CartService"
        ],
        "summary": "Retrieve user shopping cart",
        "description": "Fetches the current shopping cart contents for the specified user. Returns all items and their quantities in the cart.",
        "operationId": "getCart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/cart/{userId}/add": {
      "post": {
        "tags": [
          "CartService"
        ],
        "summary": "Add item to shopping cart",
        "description": "Adds a specified product to the user's shopping cart. Updates the cart with the new item and quantity.",
        "operationId": "addToCart",
        "parameters": [],
        "requestBody": {
          "description": "Request body representing an item to be added to a user's shopping cart.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "abc123",
                "quantity": 2,
                "color": "red",
                "size": "M"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/place/{userId}": {
      "post": {
        "tags": [
          "OrderService"
        ],
        "summary": "Place a new order",
        "description": "Creates an order based on the user's current cart items. Initiates the ordering process and prepares the order for payment and shipping.",
        "operationId": "placeOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/userId"
        }
      ]
    },
    "/orders/{orderId}": {
      "get": {
        "tags": [
          "OrderService"
        ],
        "summary": "Retrieve order details",
        "description": "Fetches detailed information about a specific order by its ID. Includes status, items, and other relevant order data.",
        "operationId": "getOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/order_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/orderId"
        }
      ]
    },
    "/payments/initiate": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Start payment process",
        "description": "Initiates a payment for an order or service. Prepares the payment transaction and returns necessary details to proceed.",
        "operationId": "initiatePayment",
        "parameters": [],
        "requestBody": {
          "description": "Request body containing payment details to initiate a transaction.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_request"
              },
              "example": {
                "userId": "user456",
                "cartId": "cart789",
                "paymentMethod": "credit_card",
                "amount": 59.99,
                "currency": "USD"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/payments/webhook": {
      "post": {
        "tags": [
          "PaymentService"
        ],
        "summary": "Receive payment notifications",
        "description": "Handles incoming webhook notifications from payment providers. Processes payment status updates and triggers related workflows.",
        "operationId": "paymentWebhook",
        "parameters": [],
        "requestBody": {
          "description": "Payload sent by the payment gateway to notify about payment status updates.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/payment_webhook"
              },
              "example": {
                "transactionId": "tx123456789",
                "status": "completed",
                "amount": 59.99,
                "currency": "USD",
                "timestamp": "2024-06-15T12:00:00Z"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/payment_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/products": {
      "post": {
        "tags": [
          "ProductService"
        ],
        "summary": "Create a new product",
        "description": "Adds a new product to the product catalog. Requires product details and returns confirmation upon successful creation.",
        "operationId": "addProduct",
        "parameters": [],
        "requestBody": {
          "description": "Request body to add a new product to the inventory.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/product_request"
              },
              "example": {
                "name": "Wireless Earbuds",
                "description": "High-quality wireless earbuds with noise cancellation",
                "price": 99.99,
                "category": "Electronics",
                "stock": 150
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/product_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    },
    "/shipping/{orderId}/track": {
      "get": {
        "tags": [
          "ShippingService"
        ],
        "summary": "Get order shipment status",
        "description": "Retrieves the current tracking information for a shipped order. Provides details on delivery progress and estimated arrival.",
        "operationId": "trackOrder",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/tracking_response"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": [
        {
          "$ref": "#/components/parameters/orderId"
        }
      ]
    },
    "/users": {
      "post": {
        "tags": [
          "UserService"
        ],
        "summary": "Register a new user",
        "description": "Creates a new user account with the provided registration information. Validates input and returns user credentials or confirmation.",
        "operationId": "registerUser",
        "parameters": [],
        "requestBody": {
          "description": "Request body containing user information for account registration.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/user_request"
              },
              "example": {
                "username": "johndoe",
                "email": "johndoe@example.com",
                "password": "secureP@ssw0rd",
                "firstName": "John",
                "lastName": "Doe"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
