  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price, following ISO 4217 standard.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item price.",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discounts.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier for the product.",
            "example": "abc123xyz"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items currently in the shopping cart.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 15.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts, taxes, and other adjustments.",
            "format": "double",
            "example": 29.99
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original amount before any discounts or adjustments are applied.",
            "format": "double",
            "example": 35.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the cart.",
            "format": "double",
            "example": 5.99
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated.",
            "example": "2024-06-10T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart.",
            "example": "user_987654321"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the order item in monetary value",
            "format": "double",
            "example": 5.75
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying discounts for the order item",
            "format": "double",
            "example": 29.25
          },
          "price": {
            "type": "number",
            "description": "The original price per unit of the product",
            "format": "double",
            "example": 35.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "PROD-987654"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for the product",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The timestamp when the order was created",
            "example": "2024-05-20T15:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "Currency code used for the order",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "item123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "itemId": "item456",
                "name": "Keyboard",
                "quantity": 1,
                "price": 45.0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD789456123"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount payable after discounts",
            "format": "double",
            "example": 70.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying discounts",
            "format": "double",
            "example": 95.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 25.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the order was last updated",
            "example": "2024-05-22T10:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier for the user who placed the order",
            "example": "user12345"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid in the specified currency",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code in ISO 4217 format for the payment amount",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "A unique identifier for the order associated with this payment",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The service provider processing the payment",
            "example": "Stripe"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The method used by the customer to make the payment",
            "example": "Credit Card"
