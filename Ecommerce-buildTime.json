  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices, following ISO 4217 format",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount applied to the item price",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discounts",
            "format": "double",
            "example": 20.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discounts",
            "format": "double",
            "example": 25.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart totals",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 30.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 61.0
          },
          "totalAmount": {
            "type": "number",
            "description": "Total original amount before discounts",
            "format": "double",
            "example": 70.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied on the cart",
            "format": "double",
            "example": 9.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-01T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_789"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after discounts",
            "format": "double",
            "example": 24.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 29.99
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units ordered for the product",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-01T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 59.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD202406011430"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts and taxes",
            "format": "double",
            "example": 89.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current status of the payment for the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original amount of the order before discounts",
            "format": "double",
            "example": 100.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 10.02
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-02T09:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "USR78910"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "The ISO currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
