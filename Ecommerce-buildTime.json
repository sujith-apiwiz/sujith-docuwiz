  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices, following ISO 4217 standard",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item, in the specified currency",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying discounts, in the specified currency",
            "format": "double",
            "example": 95.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item, in the specified currency",
            "format": "double",
            "example": 100.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the amounts listed in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "itemId": "1234",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before any discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp of the last update to the cart",
            "example": "2024-06-01T15:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_987654321"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the order item",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after applying discounts",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product before discounts",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-05-15T10:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "abc123",
                "name": "Wireless Mouse",
                "quantity": 1,
                "price": 29.99
              },
              {
                "itemId": "def456",
                "name": "Keyboard",
                "quantity": 1,
                "price": 49.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD789456123"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount payable after discounts and taxes",
            "format": "double",
            "example": 68.99
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current fulfillment status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total price of all items before discounts",
            "format": "double",
            "example": 79.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 10.99
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-05-16T14:20:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "USER123456"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Total amount to be paid",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "Currency code in ISO 4217 format",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
