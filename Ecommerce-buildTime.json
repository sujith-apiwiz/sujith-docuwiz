  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the pricing, following ISO 4217 format.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item, in the specified currency.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying the discount, in the specified currency.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before any discounts, in the specified currency.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "PROD12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items present in the shopping cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount payable after all discounts",
            "format": "double",
            "example": 59.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total original amount before discounts",
            "format": "double",
            "example": 70.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the original amount",
            "format": "double",
            "example": 10.02
          },
          "updatedAt": {
            "type": "string",
            "description": "The datetime when the cart was last updated",
            "example": "2024-04-27T15:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_98765"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the order item in monetary units.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after discount.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product before discount.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The amount of units of the product ordered.",
            "example": 1
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the order was created",
            "example": "2024-06-15T08:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "Currency code for the order amounts in ISO 4217 format",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount payable after discounts",
            "format": "double",
            "example": 49.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total order amount before discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the order was last updated",
            "example": "2024-06-16T14:45:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user_78901"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid in the specified currency.",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 currency code for the payment (e.g., USD, EUR).",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the associated order.",
            "example": "ORD123456789"
