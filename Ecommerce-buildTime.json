  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price, following ISO 4217 standards",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item, represented as a decimal number",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts",
            "format": "double",
            "example": 25.99
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before any discounts",
            "format": "double",
            "example": 30.99
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "ABC123XYZ"
          },
          "productName": {
            "type": "string",
            "description": "The name or title of the product",
            "example": "Wireless Earbuds"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts",
            "format": "double",
            "example": 45.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of all items before discounts",
            "format": "double",
            "example": 51.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 6.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The ISO 8601 timestamp indicating when the cart was last updated",
            "example": "2024-06-15T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier for the user owning the cart",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying the discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The timestamp when the order was created.",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order payment.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "The list of items included in the order.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 15.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier of the order.",
            "example": "ORD-20240615-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts.",
            "format": "double",
            "example": 75.48
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current status of the order.",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of the order before any discounts.",
            "format": "double",
            "example": 85.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the order.",
            "format": "double",
            "example": 9.52
          },
          "updatedAt": {
            "type": "string",
            "description": "The timestamp when the order was last updated.",
            "example": "2024-06-16T09:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "The unique identifier for the user who placed the order.",
            "example": "user_789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 99.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
