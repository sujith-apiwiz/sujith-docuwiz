  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price, following ISO 4217 standard",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item, in the specified currency",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts, in the specified currency",
            "format": "double",
            "example": 14.99
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product before discounts",
            "format": "double",
            "example": 20.98
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts",
            "format": "double",
            "example": 59.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The original total amount before any discounts",
            "format": "double",
            "example": 69.99
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 10.01
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp of the last update to the cart",
            "example": "2024-06-01T15:23:45Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who owns the cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item",
            "format": "double",
            "example": 5.75
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 24.25
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "prd-1001"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for the product",
            "example": 3
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created.",
            "example": "2024-06-15T14:28:23Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order transaction.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items included in the order.",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order.",
            "example": "ORD789456123"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after applying discounts.",
            "format": "double",
            "example": 51.0
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order.",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current status of the order processing.",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total order amount before any discounts.",
            "format": "double",
            "example": 60.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order.",
            "format": "double",
            "example": 9.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated.",
            "example": "2024-06-16T09:15:00Z"
          },
          "userId": {
            "type": "string",
