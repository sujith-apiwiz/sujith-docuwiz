  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime is a comprehensive API that provides essential services for managing products, user carts, orders, payments, shipping tracking, and user information within an ecommerce platform. It enables seamless interaction with cart management, order placement and tracking, payment initiation and webhook handling, product listing, and user data handling to facilitate a complete ecommerce experience.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
