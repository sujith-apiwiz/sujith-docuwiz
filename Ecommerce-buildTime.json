{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecommerce-buildTime",
    "description": "Ecommerce-buildTime is a comprehensive API designed to support all critical functionalities of an ecommerce platform, including managing user accounts, product listings, shopping carts, orders, payments, and shipping tracking. It provides endpoints for seamless shopping experiences, secure payment initiation and webhook handling, order placement and retrieval, as well as detailed product and shipping services.",
    "termsOfService": "https://www.ecommerce-buildtime.com/terms",
    "contact": {
      "name": "Ecommerce API Support",
      "url": "https://www.ecommerce-buildtime.com/support",
      "email": "support@ecommerce-buildtime.com"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
