  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code of the item's price, following ISO 4217 standards",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item's price",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discounts",
            "format": "double",
            "example": 20.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discounts",
            "format": "double",
            "example": 25.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "12345-abc"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart totals",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 20.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 41.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Sum of item prices before discounts",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-15T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier for the user owning the cart",
            "example": "user_98765"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts",
            "format": "double",
            "example": 24.99
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 30.49
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "PRD123456"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for this product",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-04-26T15:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 49.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD123456789"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts",
            "format": "double",
            "example": 58.99
          },
          "paymentStatus": {
            "type": "string",
            "description": "Status of the payment for the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount of the order before discounts",
            "format": "double",
            "example": 69.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
