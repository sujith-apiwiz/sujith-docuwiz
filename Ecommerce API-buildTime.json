{
  "openapi": "3.0.0",
  "info": {
    "title": "Ecommerce API",
    "description": "This API allows users to interact with an ecommerce platform where they can manage products, place orders, and obtain information about their purchases.",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "openapi": "3.0.0",
    "info": {
      "title": "Store API",
      "version": "1.0.0",
      "description": "API for managing products and orders in the store."
    },
    "paths": {
      "/products": {
        "get": {
          "tags": [
            "Products"
          ],
          "summary": "Retrieve a list of products",
          "description": "Returns a list of all available products in the store.",
          "operationId": "getProducts",
          "responses": {
            "200": {
              "description": "A list of products",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ProductList"
                  },
                  "examples": {
                    "example1": {
                      "value": [
                        {
                          "id": "123",
                          "name": "Product A",
                          "price": 19.99,
                          "inStock": true
                        },
                        {
                          "id": "124",
                          "name": "Product B",
                          "price": 29.99,
                          "inStock": false
                        }
                      ]
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid request parameters",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ClientErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Internal server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ServerErrorResponse"
                  }
                }
              }
            }
          }
        }
      },
      "/orders": {
        "post": {
          "tags": [
            "Orders"
          ],
          "summary": "Create a new order",
          "description": "Allows users to create a new order by providing the required order details.",
          "operationId": "createOrder",
          "requestBody": {
            "description": "Order details to be created",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderRequest"
                },
                "examples": {
                  "newOrder": {
                    "value": {
                      "userId": "456",
                      "items": [
                        {
                          "productId": "123",
                          "quantity": 2
                        },
                        {
                          "productId": "124",
                          "quantity": 1
                        }
                      ],
                      "totalPrice": 69.97,
                      "address": "123 Main St, Anytown, USA"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Order created successfully",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/OrderResponse"
                  },
                  "examples": {
                    "createdOrder": {
                      "value": {
                        "orderId": "789",
                        "status": "Processing",
                        "estimatedDelivery": "2023-11-01"
                      }
                    }
                  }
                }
              }
            },
            "422": {
              "description": "Unprocessable entity due to validation errors",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ValidationErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Internal server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ServerErrorResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "ProductList": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Product"
          }
        },
        "Product": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for the product",
              "example": "123"
            },
            "name": {
              "type": "string",
              "description": "Name of the product",
              "example": "Product A"
            },
            "price": {
              "type": "number",
              "description": "Price of the product",
              "example": 19.99
            },
            "inStock": {
              "type": "boolean",
              "description": "Availability of the product",
              "example": true
            }
          }
        },
        "OrderRequest": {
          "type": "object",
          "properties": {
            "userId": {
              "type": "string",
              "description": "Unique identifier for the user placing the order",
              "example": "456"
            },
            "items": {
              "type": "array",
              "description": "List of items included in the order",
              "items": {
                "$ref": "#/components/schemas/OrderItem"
              }
            },
            "totalPrice": {
              "type": "number",
              "description": "Total price of the order",
              "example": 69.97
            },
            "address": {
              "type": "string",
              "description": "Delivery address for the order",
              "example": "123 Main St, Anytown, USA"
            }
          },
          "required": [
            "userId",
            "items",
            "totalPrice",
            "address"
          ]
        },
        "OrderItem": {
          "type": "object",
          "properties": {
            "productId": {
              "type": "string",
              "description": "Unique identifier for the product",
              "example": "123"
            },
            "quantity": {
              "type": "integer",
              "description": "Quantity of the product ordered",
              "example": 2
            }
          }
        },
        "OrderResponse": {
          "type": "object",
          "properties": {
            "orderId": {
              "type": "string",
              "description": "Unique identifier for the created order",
              "example": "789"
            },
            "status": {
              "type": "string",
              "description": "Current status of the order",
              "example": "Processing"
            },
            "estimatedDelivery": {
              "type": "string",
              "description": "Estimated delivery date for the order",
              "example": "2023-11-01"
            }
          }
        },
        "ClientErrorResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "Error message describing why the request was invalid",
              "example": "Invalid request parameters"
            },
            "errorCode": {
              "type": "integer",
              "description": "Specific error code for tracking",
              "example": 4001
            },
            "parameter": {
              "type": "string",
              "description": "Specific parameter that caused the error",
              "example": "productId"
            },
            "type": {
              "type": "string",
              "description": "Type of the error",
              "example": "Client Error"
            },
            "timestamp": {
              "type": "string",
              "description": "Time when the error occurred",
              "example": "2023-10-05T08:00:00Z"
            },
            "requestId": {
              "type": "string",
              "description": "Identifier for the request for debugging purposes",
              "example": "req-12345"
            },
            "documentationUrl": {
              "type": "string",
              "description": "URL to the API documentation for further reference",
              "example": "http://api.example.com/docs/errors"
            }
          },
          "required": [
            "message",
            "errorCode",
            "timestamp",
            "requestId"
          ]
        },
        "ValidationErrorResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "Error message describing why the request could not be processed",
              "example": "Validation failed for the order request"
            },
            "errorCode": {
              "type": "integer",
              "description": "Specific error code for tracking",
              "example": 4221
            },
            "field": {
              "type": "string",
              "description": "Field that failed validation",
              "example": "totalPrice"
            },
            "invalidValue": {
              "type": "string",
              "description": "The value that caused the validation error",
              "example": "NaN"
            },
            "type": {
              "type": "string",
              "description": "Type of the error",
              "example": "Validation Error"
            },
            "timestamp": {
              "type": "string",
              "description": "Time when the error occurred",
              "example": "2023-10-05T08:00:00Z"
            },
            "requestId": {
              "type": "string",
              "description": "Identifier for the request for debugging purposes",
              "example": "req-67890"
            }
          },
          "required": [
            "message",
            "errorCode",
            "timestamp",
            "requestId"
          ]
        },
        "ServerErrorResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "Generic error message about the server-side error",
              "example": "An unexpected error occurred on the server"
            },
            "errorCode": {
              "type": "integer",
              "description": "Specific error code for server error tracking",
              "example": 5000
            },
            "type": {
              "type": "string",
              "description": "Type of the error",
              "example": "Server Error"
            },
            "details": {
              "type": "string",
              "description": "Detailed information about the error, if available",
              "example": "Null pointer exception in ProductService"
            },
            "timestamp": {
              "type": "string",
              "description": "Time when the error occurred",
              "example": "2023-10-05T08:15:00Z"
            },
            "requestId": {
              "type": "string",
              "description": "Identifier for the request for debugging purposes",
              "example": "req-09876"
            },
            "supportContact": {
              "type": "string",
              "description": "Contact information for support",
              "example": "support@example.com"
            }
          },
          "required": [
            "message",
            "errorCode",
            "timestamp",
            "requestId"
          ]
        }
      }
    }
  },
  "components": {
    "schemas": {
      "openapi": "3.0.3",
      "info": {
        "title": "E-commerce API",
        "description": "API for managing e-commerce platform operations such as product information and order processing.",
        "version": "1.0.0"
      },
      "paths": {
        "/products": {
          "get": {
            "summary": "Retrieve Product List",
            "description": "Fetch a list of all available products with their details.",
            "operationId": "getProductList",
            "responses": {
              "200": {
                "description": "A list of products.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ProductList"
                    },
                    "examples": {
                      "example1": {
                        "value": [
                          {
                            "id": 1,
                            "name": "Wireless Mouse",
                            "price": 19.99,
                            "quantity": 100,
                            "description": "A reliable wireless mouse with long battery life.",
                            "category": "Electronics"
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "400": {
                "description": "Client error response for invalid requests.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ClientErrorResponse"
                    }
                  }
                }
              },
              "500": {
                "description": "Server error response for unexpected errors.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ServerErrorResponse"
                    }
                  }
                }
              }
            },
            "tags": [
              "Products"
            ]
          }
        },
        "/orders": {
          "post": {
            "summary": "Create a New Order",
            "description": "Submit a new order with customer and product details.",
            "operationId": "createOrder",
            "requestBody": {
              "description": "Order details to be processed.",
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/OrderRequest"
                  },
                  "examples": {
                    "example1": {
                      "value": {
                        "customerId": 456,
                        "products": [
                          {
                            "productId": 1,
                            "quantity": 2
                          }
                        ],
                        "shippingAddress": "123 Market St, San Francisco, CA 94103",
                        "paymentMethod": "Credit Card"
                      }
                    }
                  }
                }
              }
            },
            "responses": {
              "200": {
                "description": "Order created successfully.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/OrderResponse"
                    },
                    "examples": {
                      "example1": {
                        "value": {
                          "orderId": 101,
                          "status": "Pending",
                          "totalAmount": 39.98,
                          "orderedAt": "2023-10-05T14:48:00.000Z"
                        }
                      }
                    }
                  }
                }
              },
              "422": {
                "description": "Validation error response for invalid order details.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ValidationErrorResponse"
                    }
                  }
                }
              },
              "500": {
                "description": "Server error response for unexpected errors.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ServerErrorResponse"
                    }
                  }
                }
              }
            },
            "tags": [
              "Orders"
            ]
          }
        }
      },
      "components": {
        "schemas": {
          "ProductList": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            },
            "description": "List of products available in the store.",
            "example": [
              {
                "id": 1,
                "name": "Wireless Mouse",
                "price": 19.99,
                "quantity": 100,
                "description": "A reliable wireless mouse with long battery life.",
                "category": "Electronics"
              }
            ]
          },
          "Product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Unique identifier for the product.",
                "example": 1
              },
              "name": {
                "type": "string",
                "description": "Name of the product.",
                "example": "Wireless Mouse"
              },
              "price": {
                "type": "number",
                "format": "float",
                "description": "Price of the product.",
                "example": 19.99
              },
              "quantity": {
                "type": "integer",
                "description": "Available stock quantity.",
                "example": 100
              },
              "description": {
                "type": "string",
                "description": "Product description.",
                "example": "A reliable wireless mouse with long battery life."
              },
              "category": {
                "type": "string",
                "description": "Category of the product.",
                "example": "Electronics"
              }
            }
          },
          "OrderRequest": {
            "type": "object",
            "properties": {
              "customerId": {
                "type": "integer",
                "description": "Unique identifier for the customer.",
                "example": 456
              },
              "products": {
                "type": "array",
                "description": "List of products to order with their quantities.",
                "items": {
                  "type": "object",
                  "properties": {
                    "productId": {
                      "type": "integer",
                      "description": "Unique identifier of the product.",
                      "example": 1
                    },
                    "quantity": {
                      "type": "integer",
                      "description": "Quantity of the product to order.",
                      "example": 2
                    }
                  },
                  "required": [
                    "productId",
                    "quantity"
                  ]
                }
              },
              "shippingAddress": {
                "type": "string",
                "description": "Shipping address for the order.",
                "example": "123 Market St, San Francisco, CA 94103"
              },
              "paymentMethod": {
                "type": "string",
                "description": "Payment method for the order.",
                "example": "Credit Card"
              }
            },
            "required": [
              "customerId",
              "products",
              "shippingAddress",
              "paymentMethod"
            ]
          },
          "OrderResponse": {
            "type": "object",
            "properties": {
              "orderId": {
                "type": "integer",
                "description": "Unique identifier of the created order.",
                "example": 101
              },
              "status": {
                "type": "string",
                "description": "Order status.",
                "example": "Pending"
              },
              "totalAmount": {
                "type": "number",
                "format": "float",
                "description": "Total amount for the order.",
                "example": 39.98
              },
              "orderedAt": {
                "type": "string",
                "format": "date-time",
                "description": "Timestamp when the order was placed.",
                "example": "2023-10-05T14:48:00.000Z"
              }
            },
            "required": [
              "orderId",
              "status",
              "totalAmount",
              "orderedAt"
            ]
          },
          "ClientErrorResponse": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error type.",
                "example": "InvalidRequest"
              },
              "message": {
                "type": "string",
                "description": "Detailed error message.",
                "example": "Missing required parameter: productId"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code.",
                "example": 400
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "Time when the error occurred.",
                "example": "2023-10-05T10:30:00.000Z"
              },
              "path": {
                "type": "string",
                "description": "Request path.",
                "example": "/products"
              },
              "method": {
                "type": "string",
                "description": "HTTP method used.",
                "example": "GET"
              },
              "requestId": {
                "type": "string",
                "description": "Unique identifier for the request.",
                "example": "1234abcd"
              }
            },
            "required": [
              "error",
              "message",
              "status",
              "timestamp",
              "path",
              "method",
              "requestId"
            ]
          },
          "ValidationErrorResponse": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error type.",
                "example": "ValidationError"
              },
              "message": {
                "type": "string",
                "description": "Detailed error message.",
                "example": "Product quantity must be greater than zero"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code.",
                "example": 422
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "Time when the error occurred.",
                "example": "2023-10-05T10:45:00.000Z"
              },
              "path": {
                "type": "string",
                "description": "Request path.",
                "example": "/orders"
              },
              "method": {
                "type": "string",
                "description": "HTTP method used.",
                "example": "POST"
              },
              "validationErrors": {
                "type": "array",
                "description": "List of validation error details.",
                "items": {
                  "type": "string",
                  "example": "Product quantity must be greater than zero"
                }
              }
            },
            "required": [
              "error",
              "message",
              "status",
              "timestamp",
              "path",
              "method",
              "validationErrors"
            ]
          },
          "ServerErrorResponse": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error type.",
                "example": "InternalServerError"
              },
              "message": {
                "type": "string",
                "description": "Detailed error message.",
                "example": "An unexpected error occurred on the server"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code.",
                "example": 500
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "Time when the error occurred.",
                "example": "2023-10-05T11:00:00.000Z"
              },
              "path": {
                "type": "string",
                "description": "Request path.",
                "example": "/products"
              },
              "method": {
                "type": "string",
                "description": "HTTP method used.",
                "example": "GET"
              },
              "requestId": {
                "type": "string",
                "description": "Unique identifier for the request.",
                "example": "5678efgh"
              }
            },
            "required": [
              "error",
              "message",
              "status",
              "timestamp",
              "path",
              "method",
              "requestId"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Products",
      "description": "Everything about products in the ecommerce platform"
    },
    {
      "name": "Orders",
      "description": "Operations related to order management"
    }
  ]
}