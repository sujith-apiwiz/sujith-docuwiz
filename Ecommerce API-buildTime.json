{
  "openapi": "3.0.0",
  "info": {
    "title": "Ecommerce API",
    "version": "v0",
    "description": "API for managing ecommerce operations such as creating and fetching products."
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "openapi": "3.0.1",
    "info": {
      "title": "Product Catalog API",
      "version": "1.0.0",
      "description": "API for managing a catalog of products."
    },
    "paths": {
      "/products": {
        "get": {
          "summary": "Retrieve a list of products",
          "description": "Fetch a list of all available products in the catalog.",
          "operationId": "getProducts",
          "tags": [
            "Products"
          ],
          "responses": {
            "200": {
              "description": "A list of products returned successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Product"
                    }
                  },
                  "examples": {
                    "example": {
                      "summary": "Example of product list",
                      "value": [
                        {
                          "id": "123",
                          "name": "Widget",
                          "description": "A useful widget",
                          "price": 19.99,
                          "inStock": true
                        }
                      ]
                    }
                  }
                }
              }
            },
            "404": {
              "description": "Products not found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ClientErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Internal server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ServerErrorResponse"
                  }
                }
              }
            }
          }
        },
        "post": {
          "summary": "Create a new product",
          "description": "Add a new product to the catalog.",
          "operationId": "createProduct",
          "tags": [
            "Products"
          ],
          "requestBody": {
            "description": "Product to be created.",
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewProduct"
                },
                "examples": {
                  "example": {
                    "summary": "Example of new product data",
                    "value": {
                      "name": "Gadget",
                      "description": "An innovative gadget.",
                      "price": 29.99,
                      "inStock": true
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Product created successfully.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Product"
                  },
                  "examples": {
                    "example": {
                      "summary": "Example of created product",
                      "value": {
                        "id": "124",
                        "name": "Gadget",
                        "description": "An innovative gadget.",
                        "price": 29.99,
                        "inStock": true
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid product data.",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ClientErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Internal server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ServerErrorResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "Product": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for the product.",
              "example": "123"
            },
            "name": {
              "type": "string",
              "description": "Name of the product.",
              "example": "Widget"
            },
            "description": {
              "type": "string",
              "description": "A brief description of the product.",
              "example": "A useful widget"
            },
            "price": {
              "type": "number",
              "description": "Price of the product.",
              "example": 19.99
            },
            "inStock": {
              "type": "boolean",
              "description": "Availability of the product.",
              "example": true
            }
          }
        },
        "NewProduct": {
          "type": "object",
          "required": [
            "name",
            "price",
            "inStock"
          ],
          "properties": {
            "name": {
              "type": "string",
              "description": "Name of the new product.",
              "example": "Gadget"
            },
            "description": {
              "type": "string",
              "description": "A brief description of the new product.",
              "example": "An innovative gadget."
            },
            "price": {
              "type": "number",
              "description": "Price of the new product.",
              "example": 29.99
            },
            "inStock": {
              "type": "boolean",
              "description": "Availability of the new product.",
              "example": true
            }
          }
        },
        "ClientErrorResponse": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Error status.",
              "example": "error"
            },
            "code": {
              "type": "integer",
              "description": "HTTP status code.",
              "example": 404
            },
            "message": {
              "type": "string",
              "description": "Error message.",
              "example": "Products not found."
            },
            "details": {
              "type": "string",
              "description": "Additional error details.",
              "example": "No products available in the catalog."
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp of the error.",
              "example": "2023-10-01T15:20:25Z"
            },
            "path": {
              "type": "string",
              "description": "The requested path.",
              "example": "/products"
            },
            "errors": {
              "type": "array",
              "description": "Specific parameter errors.",
              "items": {
                "type": "string",
                "example": "Product ID is required."
              }
            }
          }
        },
        "ServerErrorResponse": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "description": "Error status.",
              "example": "error"
            },
            "code": {
              "type": "integer",
              "description": "HTTP status code.",
              "example": 500
            },
            "message": {
              "type": "string",
              "description": "Error message.",
              "example": "An internal error occurred."
            },
            "details": {
              "type": "string",
              "description": "Additional error details.",
              "example": "The server encountered an unexpected condition."
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp of the error.",
              "example": "2023-10-01T15:20:30Z"
            },
            "path": {
              "type": "string",
              "description": "The requested path.",
              "example": "/products"
            },
            "errors": {
              "type": "array",
              "description": "Detailed server errors.",
              "items": {
                "type": "string",
                "example": "Database connection failed."
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "openapi": "3.0.0",
      "info": {
        "title": "Product API",
        "version": "1.0.0",
        "description": "API for managing products in the inventory."
      },
      "paths": {
        "/products": {
          "post": {
            "summary": "Create a new product",
            "description": "Adds a new product to the database with provided details such as the name, price, and description.",
            "operationId": "createProduct",
            "tags": [
              "Products"
            ],
            "requestBody": {
              "description": "The product to create",
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/NewProduct"
                  }
                }
              }
            },
            "responses": {
              "201": {
                "description": "Product created successfully.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/Product"
                    },
                    "examples": {
                      "product": {
                        "value": {
                          "id": "123",
                          "name": "New Wireless Mouse",
                          "price": 25.99,
                          "description": "An ergonomic and high-precision wireless mouse."
                        }
                      }
                    }
                  }
                }
              },
              "400": {
                "description": "Invalid input provided.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ClientErrorResponse"
                    }
                  }
                }
              },
              "500": {
                "description": "An unexpected server error occurred.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ServerErrorResponse"
                    }
                  }
                }
              }
            }
          }
        },
        "/products/{productId}": {
          "get": {
            "summary": "Retrieve a product by ID",
            "description": "Fetches information about a specific product using the unique product ID.",
            "operationId": "getProductById",
            "tags": [
              "Products"
            ],
            "parameters": [
              {
                "name": "productId",
                "in": "path",
                "required": true,
                "description": "Unique identifier of the product",
                "schema": {
                  "type": "string",
                  "example": "123"
                }
              }
            ],
            "responses": {
              "200": {
                "description": "Product retrieved successfully.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/Product"
                    },
                    "examples": {
                      "product": {
                        "value": {
                          "id": "123",
                          "name": "Wireless Mouse",
                          "price": 19.99,
                          "description": "A high-quality wireless mouse suitable for gaming and office work."
                        }
                      }
                    }
                  }
                }
              },
              "404": {
                "description": "Product not found.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ClientErrorResponse"
                    }
                  }
                }
              },
              "500": {
                "description": "An unexpected server error occurred.",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/ServerErrorResponse"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "components": {
        "schemas": {
          "Product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the product.",
                "example": "123"
              },
              "name": {
                "type": "string",
                "description": "Name of the product.",
                "example": "Wireless Mouse"
              },
              "price": {
                "type": "number",
                "description": "Price of the product.",
                "example": 19.99
              },
              "description": {
                "type": "string",
                "description": "Detailed description of the product.",
                "example": "A high-quality wireless mouse suitable for gaming and office work."
              }
            }
          },
          "NewProduct": {
            "type": "object",
            "required": [
              "name",
              "price"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the product.",
                "example": "New Wireless Mouse"
              },
              "price": {
                "type": "number",
                "description": "Price of the product.",
                "example": 25.99
              },
              "description": {
                "type": "string",
                "description": "Description of the product.",
                "example": "An ergonomic and high-precision wireless mouse."
              }
            }
          },
          "ClientErrorResponse": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer",
                "description": "HTTP status code of the error.",
                "example": 400
              },
              "error": {
                "type": "string",
                "description": "Error name or type.",
                "example": "Bad Request"
              },
              "message": {
                "type": "string",
                "description": "A human-readable message describing the error.",
                "example": "Invalid product ID."
              },
              "details": {
                "type": "string",
                "description": "Detailed information about the error.",
                "example": "The provided product ID format is incorrect."
              },
              "instance": {
                "type": "string",
                "description": "URL referencing the error instance.",
                "example": "/products/invalid-id"
              },
              "additionalInfo": {
                "type": "string",
                "description": "Any additional information regarding the error.",
                "example": "Ensure the product ID is correct."
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "The time when the error occurred.",
                "example": "2023-11-01T12:00:00Z"
              }
            }
          },
          "ServerErrorResponse": {
            "type": "object",
            "properties": {
              "statusCode": {
                "type": "integer",
                "description": "HTTP status code of the error.",
                "example": 500
              },
              "error": {
                "type": "string",
                "description": "Error name or type.",
                "example": "Internal Server Error"
              },
              "message": {
                "type": "string",
                "description": "A human-readable message describing the error.",
                "example": "An unexpected error occurred."
              },
              "details": {
                "type": "string",
                "description": "Detailed information about the error.",
                "example": "An error occurred while processing your request."
              },
              "instance": {
                "type": "string",
                "description": "URL referencing the error instance.",
                "example": "/products"
              },
              "additionalInfo": {
                "type": "string",
                "description": "Any additional information regarding the error.",
                "example": "Please try again later."
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "The time when the error occurred.",
                "example": "2023-11-01T12:00:00Z"
              }
            }
          }
        }
      }
    }
  }
}