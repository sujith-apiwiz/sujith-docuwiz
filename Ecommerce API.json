{
  "openapi": "3.0.3",
  "info": {
    "title": "Ecommerce API",
    "version": "v0",
    "description": "API for managing an ecommerce platform, providing operations for products, orders, and users."
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "openapi": "3.0.0",
    "info": {
      "title": "Product API",
      "version": "1.0.0",
      "description": "API for managing products catalog."
    },
    "paths": {
      "/products": {
        "get": {
          "tags": [
            "Product"
          ],
          "summary": "Retrieve a list of products",
          "description": "Retrieves a comprehensive list of all available products.",
          "operationId": "getProducts",
          "responses": {
            "200": {
              "description": "A list of products",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Product"
                    }
                  },
                  "example": [
                    {
                      "id": "1",
                      "name": "Smartphone",
                      "price": 299.99,
                      "quantity": 100
                    },
                    {
                      "id": "2",
                      "name": "Laptop",
                      "price": 899.99,
                      "quantity": 50
                    }
                  ]
                }
              }
            },
            "404": {
              "description": "Products not found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Error4XX"
                  }
                }
              }
            },
            "500": {
              "description": "Internal server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Error5XX"
                  }
                }
              }
            }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "Product": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique identifier for the product",
              "example": "1"
            },
            "name": {
              "type": "string",
              "description": "The name of the product",
              "example": "Smartphone"
            },
            "price": {
              "type": "number",
              "format": "float",
              "description": "The price of the product",
              "example": 299.99
            },
            "quantity": {
              "type": "integer",
              "description": "Available quantity of the product in stock",
              "example": 100
            }
          }
        },
        "Error4XX": {
          "type": "object",
          "properties": {
            "code": {
              "type": "integer",
              "description": "Error code associated with the 4XX error",
              "example": 404
            },
            "message": {
              "type": "string",
              "description": "Error message detailing the reason for the failure",
              "example": "Products not found"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "The time at which the error occurred",
              "example": "2023-04-01T12:00:00Z"
            },
            "path": {
              "type": "string",
              "description": "The request path that resulted in the error",
              "example": "/products"
            },
            "method": {
              "type": "string",
              "description": "The HTTP method used for the request",
              "example": "GET"
            },
            "requestId": {
              "type": "string",
              "description": "A unique identifier for the request",
              "example": "req_1234567890"
            },
            "additionalInfo": {
              "type": "string",
              "description": "Additional details about the error if available",
              "example": "No products available in the database"
            }
          }
        },
        "Error5XX": {
          "type": "object",
          "properties": {
            "code": {
              "type": "integer",
              "description": "Error code associated with the 5XX error",
              "example": 500
            },
            "message": {
              "type": "string",
              "description": "Error message indicating a server-side issue",
              "example": "Internal server error"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "The time at which the error occurred",
              "example": "2023-04-01T12:00:00Z"
            },
            "path": {
              "type": "string",
              "description": "The request path that resulted in the error",
              "example": "/products"
            },
            "method": {
              "type": "string",
              "description": "The HTTP method used for the request",
              "example": "GET"
            },
            "requestId": {
              "type": "string",
              "description": "A unique identifier for the request",
              "example": "req_0987654321"
            },
            "additionalInfo": {
              "type": "string",
              "description": "Additional details about the error if available",
              "example": "The server encountered an unexpected condition"
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "openapi": "3.0.0",
      "info": {
        "title": "Product API",
        "version": "1.0.0",
        "description": "API for managing products in the inventory"
      },
      "paths": {
        "/products": {
          "get": {
            "summary": "Retrieve a list of products",
            "description": "Fetches all products available in the inventory with details like id, name, price, and quantity.",
            "operationId": "getProducts",
            "tags": [
              "Products"
            ],
            "responses": {
              "200": {
                "description": "A list of products",
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "examples": {
                      "example1": {
                        "summary": "Sample product list",
                        "value": [
                          {
                            "id": "1",
                            "name": "Smartphone",
                            "price": 299.99,
                            "quantity": 100
                          }
                        ]
                      }
                    }
                  }
                }
              },
              "404": {
                "description": "Products not found",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/Error4XX"
                    }
                  }
                }
              },
              "500": {
                "description": "Internal server error",
                "content": {
                  "application/json": {
                    "schema": {
                      "$ref": "#/components/schemas/Error5XX"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "components": {
        "schemas": {
          "Product": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the product",
                "example": "1"
              },
              "name": {
                "type": "string",
                "description": "Name of the product",
                "example": "Smartphone"
              },
              "price": {
                "type": "number",
                "description": "Price of the product",
                "example": 299.99
              },
              "quantity": {
                "type": "integer",
                "description": "Available quantity of the product in stock",
                "example": 100
              }
            },
            "required": [
              "id",
              "name",
              "price",
              "quantity"
            ]
          },
          "Error4XX": {
            "type": "object",
            "properties": {
              "errorCode": {
                "type": "integer",
                "description": "Application-specific error code",
                "example": 404
              },
              "message": {
                "type": "string",
                "description": "Error message",
                "example": "Products not found"
              },
              "details": {
                "type": "string",
                "description": "Additional details about the error",
                "example": "No products available in the inventory."
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "Time at which the error occurred",
                "example": "2023-10-15T13:00:00Z"
              },
              "path": {
                "type": "string",
                "description": "Path of the API endpoint that produced the error",
                "example": "/products"
              },
              "status": {
                "type": "string",
                "description": "HTTP status code",
                "example": "404"
              },
              "cause": {
                "type": "string",
                "description": "Probable cause for the error",
                "example": "Database retrieval issue"
              }
            },
            "required": [
              "errorCode",
              "message",
              "timestamp",
              "path",
              "status"
            ]
          },
          "Error5XX": {
            "type": "object",
            "properties": {
              "errorCode": {
                "type": "integer",
                "description": "Application-specific error code",
                "example": 500
              },
              "message": {
                "type": "string",
                "description": "Error message",
                "example": "Internal server error"
              },
              "details": {
                "type": "string",
                "description": "Additional details about the error",
                "example": "An unexpected error occurred on the server."
              },
              "timestamp": {
                "type": "string",
                "format": "date-time",
                "description": "Time at which the error occurred",
                "example": "2023-10-15T13:05:00Z"
              },
              "path": {
                "type": "string",
                "description": "Path of the API endpoint that produced the error",
                "example": "/products"
              },
              "status": {
                "type": "string",
                "description": "HTTP status code",
                "example": "500"
              },
              "cause": {
                "type": "string",
                "description": "Probable cause for the error",
                "example": "Server malfunction"
              }
            },
            "required": [
              "errorCode",
              "message",
              "timestamp",
              "path",
              "status"
            ]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Product",
      "description": "Operations related to products"
    },
    {
      "name": "Order",
      "description": "Operations related to orders"
