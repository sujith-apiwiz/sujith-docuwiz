          "BillingService"
        ],
        "summary": "Initiate a billing process",
        "description": "Starts a billing transaction based on the provided billing request details. Returns the billing response including payment instructions and transaction identifiers.",
        "operationId": "initiateBilling",
        "parameters": [],
        "requestBody": {
          "description": "Billing initiation request containing payment and order details",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/billing_request"
              },
              "example": {
                "orderId": "ord-7b3d8f2a",
                "customerId": "cust-9d8e7f6a",
                "amount": 299.99,
                "currency": "USD",
                "paymentMethod": "credit_card",
                "billingAddress": {
                  "street": "456 Commerce Blvd",
                  "city": "Trade City",
                  "state": "TX",
                  "zipcode": "75001",
                  "country": "USA"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Billing transaction successfully initiated.",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/billing_response"
                }
              }
            }
          },
          "400": {
            "description": "Bad request due to invalid billing request data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/client_error_response"
                },
                "example": {
                  "error": "InvalidBillingRequest",
                  "message": "Billing request data is incomplete or contains errors.",
                  "status": 400,
                  "timestamp": "2026-01-15T10:23:45Z",
                  "path": "/billing/initiate",
                  "requestId": "req-6e1a78fc",
                  "errorCode": "INVALID_BILLING_REQUEST",
                  "details": [
                    {
                      "field": "amount",
                      "issue": "Amount must be a positive number."
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal server error occurred while initiating billing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/server_error_response"
                },
                "example": {
                  "error": "InternalServerError",
                  "message": "An unexpected error occurred. Please try again later.",
                  "status": 500,
                  "timestamp": "2026-01-15T10:23:45Z",
                  "requestId": "req-1b9d7c3a"
                }
              }
            }
          }
        },
        "callbacks": {},
        "security": [],
        "servers": []
      },
      "servers": [],
      "parameters": []
    }
  },
