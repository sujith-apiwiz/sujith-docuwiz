      "name": "CartService",
      "description": "Handles operations related to the user's shopping cart including adding, updating, and removing items."
    },
    {
      "name": "OrderService",
      "description": "Manages order processing, tracking, and history for users."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping options, tracking deliveries, and managing shipping addresses."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    },
    {
      "name": "PaymentService",
      "description": "Processes payments, handles billing information, and manages transaction history."
    },
    {
      "name": "ProductService",
      "description": "Manages product catalog, including product details, inventory, and categories."
    }
  ],
