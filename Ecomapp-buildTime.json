              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/server_error_response"
                },
                "example": {
                  "error": "InternalServerError",
                  "message": "Unexpected error occurred",
                  "status": 500,
                  "path": "/cart/{userId}/add"
                }
              }
            }
          }
        },
