  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after discounts",
            "format": "double",
            "example": 14.01
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discounts",
            "format": "double",
            "example": 20.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "12345ABC"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code used for all monetary values in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "id": "123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount the user needs to pay after discounts",
            "format": "double",
            "example": 51.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount of all items before any discounts",
            "format": "double",
            "example": 60.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart",
            "format": "double",
            "example": 8.02
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-15T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_78945"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item.",
            "format": "double",
            "example": 5.75
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after discounts.",
            "format": "double",
            "example": 45.25
          },
          "price": {
            "type": "number",
            "description": "The original price of the order item before discounts.",
            "format": "double",
            "example": 51.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product ordered.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for the product.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "Timestamp when the order was created",
            "example": "2024-06-05T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "Currency code used for the order transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 15.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD789456123"
          },
          "payableAmount": {
            "type": "number",
            "description": "Final amount to be paid after discounts",
            "format": "double",
            "example": 31.0
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before any discount applied",
            "format": "double",
            "example": 35.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount amount applied to the order",
            "format": "double",
            "example": 4.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the order was last updated",
            "example": "2024-06-06T09:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "USR654321"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid in the specified currency",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order associated with the payment",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "Name of the payment gateway processing the transaction",
            "example": "Stripe"
