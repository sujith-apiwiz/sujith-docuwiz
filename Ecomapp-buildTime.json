{
  "openapi": "3.0.1",
  "info": {
    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTime is a comprehensive e-commerce API that facilitates seamless integration of services including payment processing, cart management, shipping tracking, product catalog access, user management, and order handling. It enables developers to build robust and scalable online shopping experiences by providing endpoints to add and retrieve cart items, place and track orders, initiate payments, handle payment webhooks, browse products, and manage users.",
    "termsOfService": "https://www.ecomapp.com/terms",
    "contact": {
      "name": "Ecomapp Support",
      "url": "https://www.ecomapp.com/support",
      "email": "support@ecomapp.com"
    },
    "version": "v0"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
    }
  ],
