  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's prices",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after discount is applied",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "SKU12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for all monetary values in the cart.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items present in the shopping cart.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts and taxes.",
            "format": "double",
            "example": 39.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before applying any discounts.",
            "format": "double",
            "example": 49.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart.",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp indicating when the cart was last updated.",
            "example": "2024-06-15T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who owns the cart.",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The monetary discount applied to the order item.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after discounts.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the product.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product ordered.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-05-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 19.99
              },
              {
                "productId": "67890",
                "quantity": 1,
                "price": 49.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD-20240515-0001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount to be paid after discounts and adjustments",
            "format": "double",
            "example": 59.97
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current status of the payment for the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The overall status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total price of all items before discounts",
            "format": "double",
            "example": 69.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the order",
            "format": "double",
            "example": 10.01
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-05-16T10:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user-789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid in the transaction",
            "format": "double",
            "example": 99.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment in ISO 4217 format",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the related order",
            "example": "ORD1234567890"
