  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the item's pricing",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 15.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 84.5
          },
          "price": {
            "type": "number",
            "description": "The original price of a single unit of the item",
            "format": "double",
            "example": 100.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "PROD-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Bluetooth Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product ordered",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the amounts in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "productId": "67890",
                "name": "USB-C Cable",
                "quantity": 1,
                "price": 9.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount payable after discounts",
            "format": "double",
            "example": 45.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before applying any discounts",
            "format": "double",
            "example": 61.97
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 15.99
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-15T14:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier for the user owning the cart",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount discounted from the original price",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The total price after applying the discount",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price per unit of the product",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "prd-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-01T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order payment",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "The amount that the user needs to pay after discounts",
            "format": "double",
            "example": 49.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before discount",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-02T10:15:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "user_123456"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid, represented as a decimal number.",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment, using ISO 4217 format.",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "A unique identifier for the order associated with this payment request.",
            "example": "ORD123456789"
          },
