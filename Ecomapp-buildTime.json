  "info": {
    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTime is a comprehensive e-commerce API that provides services for managing shopping carts, orders, shipping tracking, user profiles, payments, and product listings. It enables seamless integration for building robust e-commerce applications with endpoints to add and retrieve cart items, place and track orders, initiate and handle payment processes, access product information, and manage user details.",
    "termsOfService": "https://www.ecomapp.com/terms",
    "contact": {
      "name": "Ecomapp Support Team",
      "url": "https://www.ecomapp.com/support",
      "email": "support@ecomapp.com"
    },
    "version": "v0"
  },
  "servers": [
    {
      "url": "https://acme-data-wadt.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "DEV",
      "x-hide": false,
      "x-environmentId": "689cd1fe0d6c1e475a843974",
      "x-basePath": "/v1/ecommerce"
    }
