    "/cart/{userId}/add": {
      "post": {
        "tags": [
          "CartService"
        ],
        "summary": "Add item to user's cart",
        "description": "Adds a specified product or item to the shopping cart of the given user. This operation updates the cart with new items or increases quantity if the item already exists.",
        "operationId": "addToCart",
        "parameters": [],
        "requestBody": {
          "description": "Request body to add an item to a user's shopping cart including product details and quantity.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "abc123",
                "quantity": 2,
                "options": {
                  "size": "M",
                  "color": "red"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
