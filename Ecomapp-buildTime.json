      "name": "CartService",
      "description": "Manages shopping cart functionalities such as item addition, removal, and updates."
    },
    {
      "name": "ShippingService",
      "description": "Coordinates shipping details, tracking, and delivery status updates."
    },
    {
      "name": "ProductService",
      "description": "Manages product catalog, including creation, updates, and retrieval of product information."
    },
    {
      "name": "UserService",
      "description": "Manages user accounts, authentication, and profile information."
    },
    {
      "name": "OrderService",
      "description": "Handles order processing, tracking, and status management."
    }
  ],
