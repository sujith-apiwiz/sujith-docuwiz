            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "987654321",
                "quantity": 2,
                "variantId": "blue-large"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
