    "/cart/{userId}/add": {
      "post": {
        "tags": [
          "CartService"
        ],
        "summary": "Add item to user's cart",
        "description": "Adds a specified product to the shopping cart of the given user. This operation updates the user's cart with new items or increments quantity.",
        "operationId": "addToCart",
        "parameters": [],
        "requestBody": {
          "description": "Represents the item details to be added to the user's shopping cart.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "12345",
                "quantity": 2,
                "options": {
                  "color": "red",
                  "size": "M"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response for status 200",
            "headers": {},
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/cart_response"
                }
              }
