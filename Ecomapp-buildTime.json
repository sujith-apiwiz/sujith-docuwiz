            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/cart_item"
              },
              "example": {
                "productId": "abc123",
                "quantity": 2,
                "options": {
                  "size": "M",
                  "color": "red"
                }
              }
            }
          }
        },
