                "example": {
                  "error": "BadRequest",
                  "message": "Invalid input for /cart/{userId}/add",
                  "status": 400,
                  "path": "/cart/{userId}/add"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
