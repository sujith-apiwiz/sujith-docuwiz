  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code of the item's price, e.g., USD, EUR",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "Discount amount applied on the item",
            "format": "double",
            "example": 5.25
          },
          "finalPrice": {
            "type": "number",
            "description": "Final price after discount for the item",
            "format": "double",
            "example": 19.75
          },
          "price": {
            "type": "number",
            "description": "Original price per unit of the item",
            "format": "double",
            "example": 25.0
          },
          "productId": {
            "type": "string",
            "description": "Unique identifier of the product",
            "example": "prod_12345"
          },
          "productName": {
            "type": "string",
            "description": "Name of the product",
            "example": "Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units of the product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code used for all amounts in the cart",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the shopping cart",
            "example": [
              {
                "currency": "USD",
                "discount": 5.25,
                "finalPrice": 19.75,
                "price": 25.0,
                "productId": "prod_12345",
                "productName": "Wireless Headphones",
                "quantity": 2
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount payable after discounts",
            "format": "double",
            "example": 39.5
          },
          "totalAmount": {
            "type": "number",
            "description": "Total original amount before discounts",
            "format": "double",
            "example": 50.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Sum of all discounts applied in the cart",
            "format": "double",
            "example": 10.5
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated in ISO 8601 format",
            "example": "2024-06-01T14:48:00.000Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_98765"
          }
        }
      },
      "order_item": {
