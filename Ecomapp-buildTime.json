  "info": {
    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTimes is an e-commerce API that enables comprehensive management of products, users, shipping, cart operations, payments, and orders. It offers endpoints for adding and retrieving cart items, placing and tracking orders, initiating payments, handling payment webhooks, managing product listings, and user information, facilitating seamless e-commerce workflows.",
    "termsOfService": "https://www.ecomapp.com/terms",
    "contact": {
      "name": "Ecomapp Support Team",
      "url": "https://www.ecomapp.com/support",
      "email": "support@ecomapp.com"
    },
    "version": "v0"
  },
  "servers": [
    {
      "url": "https://acme-data-wadt.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
