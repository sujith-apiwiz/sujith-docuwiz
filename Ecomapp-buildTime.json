  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item.",
            "format": "double",
            "example": 5.99
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 24.01
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discounts.",
            "format": "double",
            "example": 30.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart amounts.",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart.",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Final amount to be paid after discounts.",
            "format": "double",
            "example": 59.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying any discounts.",
            "format": "double",
            "example": 69.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart.",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated.",
            "example": "2024-06-15T13:45:30Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who owns the cart.",
            "example": "user_7890"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the order item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after applying discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the order item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T13:45:30Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts and taxes",
            "format": "double",
            "example": 51.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order",
            "example": "Processing"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total price of all items before any discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discounts applied to the order",
            "format": "double",
            "example": 8.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T10:30:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "USR123456789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid in the transaction",
            "format": "double",
            "example": 149.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment amount as per ISO 4217 standard",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order associated with the payment",
            "example": "ORD123456789"
          },
          "paymentGateway": {
