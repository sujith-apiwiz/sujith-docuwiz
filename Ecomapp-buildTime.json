  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The amount of discount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "abc123"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of this product in the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the cart amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 29.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid after discounts",
            "format": "double",
            "example": 49.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total price of all items before discounts",
            "format": "double",
            "example": 59.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-01T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user owning the cart",
            "example": "user_98765"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the item, represented as a decimal value.",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 44.5
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before any discounts.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for this item.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order transactions",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 19.99
              },
              {
                "itemId": "67890",
                "name": "USB-C Cable",
                "quantity": 1,
                "price": 9.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD202406150001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts and adjustments",
            "format": "double",
            "example": 49.97
          },
          "paymentStatus": {
            "type": "string",
            "description": "The current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "The current status of the order processing",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount before discounts are applied",
            "format": "double",
            "example": 59.97
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount amount applied to the order",
            "format": "double",
            "example": 10.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-15T16:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user who placed the order",
            "example": "user_789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid.",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "The currency code in which the payment is made.",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order associated with the payment.",
