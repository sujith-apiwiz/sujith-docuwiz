  "info": {
    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTime is a comprehensive e-commerce API encompassing cart management, order processing, shipping tracking, user management, payment handling, and product catalog services. It enables developers to integrate robust functionalities such as adding items to carts, placing orders, initiating payments, tracking shipments, and managing user data all within a single unified platform.",
    "termsOfService": "https://www.ecomapp-buildtime.com/terms",
    "contact": {
      "name": "Ecomapp Support Team",
      "url": "https://www.ecomapp-buildtime.com/support",
      "email": "support@ecomapp-buildtime.com"
    },
    "version": "v0"
  },
  "servers": [
    {
      "url": "https://acme-banking.apiwiz.io/v1/ecommerce",
      "description": "Dev",
      "variables": {},
      "x-schema": "https://",
      "x-name": "Dev",
      "x-environmentName": "Dev",
      "x-hide": false,
      "x-environmentId": "69e1f78a1cdbcc768483599a",
      "x-basePath": "/v1/ecommerce"
