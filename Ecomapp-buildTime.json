  "info": {
    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTime is a comprehensive e-commerce API that provides a wide range of services including managing user carts, placing and tracking orders, handling payments, managing products, and facilitating shipping tracking. It is designed to streamline online shopping experiences by integrating Cart, Order, Shipping, User, Payment, and Product services into a unified platform.",
    "termsOfService": "https://www.ecomapp.com/terms",
    "contact": {
      "name": "Ecomapp Support Team",
      "url": "https://www.ecomapp.com/support",
      "email": "support@ecomapp.com"
    },
    "version": "v0"
  },
