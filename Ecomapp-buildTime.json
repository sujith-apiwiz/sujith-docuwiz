  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the prices in ISO 4217 format.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before any discounts.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "SKU123456"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "Currency code used for the cart pricing",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 15.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "Final amount payable after discounts",
            "format": "double",
            "example": 29.98
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying discounts",
            "format": "double",
            "example": 35.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the cart",
            "format": "double",
            "example": 5.02
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-15T12:34:56Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user owning the cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the order item in the currency's unit.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying the discount.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the order item before discount.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units ordered for this item.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T14:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "itemId": "item123",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              },
              {
                "itemId": "item456",
                "name": "Mechanical Keyboard",
                "quantity": 1,
                "price": 89.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD20240615001"
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts",
            "format": "double",
            "example": 115.99
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount before applying any discounts",
            "format": "double",
            "example": 141.97
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 25.98
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T10:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier of the user who placed the order",
            "example": "user789"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Total amount to be paid",
            "format": "double",
            "example": 159.99
          },
          "currency": {
            "type": "string",
            "description": "Currency code in ISO 4217 format",
            "example": "USD"
