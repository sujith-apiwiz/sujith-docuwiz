    "title": "Ecomapp-buildTime",
    "description": "Ecomapp-buildTime is a comprehensive e-commerce API designed to handle user management, product catalog, shopping cart operations, order processing, payment initiation and webhook handling, as well as shipping tracking. This API enables seamless integration of critical e-commerce functionalities to build robust online shopping experiences.",
    "termsOfService": "https://www.ecomapp.com/terms",
    "contact": {
      "name": "Ecomapp Support",
      "url": "https://www.ecomapp.com/support",
      "email": "support@ecomapp.com"
    },
    "version": "v0"
  },
