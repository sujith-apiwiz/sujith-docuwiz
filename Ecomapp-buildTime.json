  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code of the item's price according to ISO 4217.",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after applying discounts.",
            "format": "double",
            "example": 19.99
          },
          "price": {
            "type": "number",
            "description": "The original price of a single item before discounts.",
            "format": "double",
            "example": 24.99
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product.",
            "example": "12345ABC"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The number of units of the product in the cart.",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code used for the transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items currently in the shopping cart",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 25.0
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable after discounts",
            "format": "double",
            "example": 45.5
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of all items before discounts",
            "format": "double",
            "example": 50.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 4.5
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp indicating when the cart was last updated",
            "example": "2024-06-01T12:00:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user owning the cart",
            "example": "user_78910"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The monetary discount applied to the order item",
            "format": "double",
            "example": 5.5
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price after applying discounts",
            "format": "double",
            "example": 44.5
          },
          "price": {
            "type": "number",
            "description": "The original unit price of the product",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product",
            "example": "B07PGL2ZSL"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Bluetooth Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-01T12:34:56Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code used for the order amounts",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the order",
            "example": [
              {
                "productId": "12345",
                "quantity": 2,
                "price": 25.5
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "Total amount to be paid for the order after discounts",
            "format": "double",
            "example": 45.0
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current processing status of the order",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total amount of the order before any discounts",
            "format": "double",
            "example": 50.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 5.0
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-02T08:15:30Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier for the user who placed the order",
            "example": "USER123456"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 150.75
          },
          "currency": {
            "type": "string",
            "description": "The currency code in which the payment is made",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "The unique identifier for the order related to the payment",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The name of the payment gateway processing the transaction",
            "example": "Stripe"
          },
          "paymentMethod": {
            "type": "string",
            "description": "The method used for payment (e.g., credit card, PayPal)",
            "example": "Credit Card"
          }
        }
      },
      "payment_response": {
        "type": "object",
        "properties": {
