  "components": {
    "schemas": {
      "cart_item": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the item's price",
            "example": "USD"
          },
          "discount": {
            "type": "number",
            "description": "The discount amount applied to the item",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the item after discount",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price of the item before discount",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier of the product",
            "example": "prod-12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product",
            "example": "Wireless Mouse"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product added to the cart",
            "example": 2
          }
        }
      },
      "cart_response": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string",
            "description": "The currency code for the cart's monetary values",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "List of items included in the cart",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/cart_item"
            }
          },
          "payableAmount": {
            "type": "number",
            "description": "The final amount to be paid after discounts",
            "format": "double",
            "example": 47.98
          },
          "totalAmount": {
            "type": "number",
            "description": "The total price of all items before any discounts",
            "format": "double",
            "example": 51.98
          },
          "totalDiscount": {
            "type": "number",
            "description": "The total discount applied to the cart",
            "format": "double",
            "example": 4.0
          },
          "updatedAt": {
            "type": "string",
            "description": "Timestamp when the cart was last updated",
            "example": "2024-06-01T15:20:30Z"
          },
          "userId": {
            "type": "string",
            "description": "Unique identifier of the cart owner",
            "example": "user_987654321"
          }
        }
      },
      "order_item": {
        "type": "object",
        "properties": {
          "discount": {
            "type": "number",
            "description": "The discount applied to the order item in currency units.",
            "format": "double",
            "example": 5.0
          },
          "finalPrice": {
            "type": "number",
            "description": "The final price of the order item after applying discounts.",
            "format": "double",
            "example": 45.0
          },
          "price": {
            "type": "number",
            "description": "The original price per unit of the product before discounts.",
            "format": "double",
            "example": 50.0
          },
          "productId": {
            "type": "string",
            "description": "The unique identifier for the product.",
            "example": "PROD12345"
          },
          "productName": {
            "type": "string",
            "description": "The name of the product ordered.",
            "example": "Wireless Headphones"
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of the product ordered.",
            "example": 2
          }
        }
      },
      "order_response": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "description": "The date and time when the order was created",
            "example": "2024-06-15T08:30:00Z"
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the transaction",
            "example": "USD"
          },
          "items": {
            "type": "array",
            "description": "A list of items included in the order",
            "example": [
              {
                "itemId": "12345",
                "name": "Wireless Mouse",
                "quantity": 2,
                "price": 25.99
              }
            ],
            "items": {
              "$ref": "#/components/schemas/order_item"
            }
          },
          "orderId": {
            "type": "string",
            "description": "Unique identifier for the order",
            "example": "ORD987654321"
          },
          "payableAmount": {
            "type": "number",
            "description": "The total amount payable for the order after discounts and taxes",
            "format": "double",
            "example": 51.98
          },
          "paymentStatus": {
            "type": "string",
            "description": "Current payment status of the order",
            "example": "Paid"
          },
          "status": {
            "type": "string",
            "description": "Current status of the order processing",
            "example": "Shipped"
          },
          "totalAmount": {
            "type": "number",
            "description": "The total amount of the order before discounts",
            "format": "double",
            "example": 60.0
          },
          "totalDiscount": {
            "type": "number",
            "description": "Total discount applied to the order",
            "format": "double",
            "example": 8.02
          },
          "updatedAt": {
            "type": "string",
            "description": "The date and time when the order was last updated",
            "example": "2024-06-16T12:45:00Z"
          },
          "userId": {
            "type": "string",
            "description": "Identifier for the user who placed the order",
            "example": "user12345"
          }
        }
      },
      "payment_request": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "The total amount to be paid",
            "format": "double",
            "example": 199.99
          },
          "currency": {
            "type": "string",
            "description": "The currency code for the payment",
            "example": "USD"
          },
          "orderId": {
            "type": "string",
            "description": "A unique identifier for the order",
            "example": "ORD123456789"
          },
          "paymentGateway": {
            "type": "string",
            "description": "The name of the payment gateway used",
